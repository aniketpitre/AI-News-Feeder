# Google Gemini API Key
# Get it for free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Site URL for production
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: Customize sync intervals (in milliseconds)
# SYNC_INTERVAL_PRIMARY=3600000  # 1 hour
# SYNC_INTERVAL_BACKUP=1800000   # 30 minutes
